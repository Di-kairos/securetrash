#!/usr/bin/env bash
echo "$@" >> "${HOME}/hdiutil_calls.log"
case "$1" in
  create)
    for a in "$@"; do last="$a"; done
    : > "$last" 2>/dev/null || true ;;
  attach) : ;;
  detach)
    # ST_MOCK_DETACH_FAIL=1 → detach падает (том «занят»), маркер не ставим.
    [[ "${ST_MOCK_DETACH_FAIL:-0}" == "1" ]] && exit 1
    # успешный detach → помечаем «отцеплен», чтобы последующий info это отразил.
    touch "${HOME}/.st_detached" 2>/dev/null || true ;;
  info)
    # ST_MOCK_INFO_FAIL=1 → hdiutil info недоступен → состояние unknown.
    [[ "${ST_MOCK_INFO_FAIL:-0}" == "1" ]] && exit 1
    # `info -plist`: ST_MOCK_VAULT_ATTACHED=1 И не было detach → образ примонтирован.
    if [[ "${2:-}" == "-plist" ]]; then
      if [[ "${ST_MOCK_VAULT_ATTACHED:-0}" == "1" && ! -e "${HOME}/.st_detached" ]]; then
        cat <<EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>images</key>
  <array>
    <dict>
      <key>image-path</key><string>${HOME}/SecureVault.sparsebundle</string>
      <key>system-entities</key>
      <array>
        <dict>
          <key>dev-entry</key><string>/dev/disk99</string>
          <key>mount-point</key><string>/Volumes/SecretVault</string>
        </dict>
      </array>
    </dict>
  </array>
</dict>
</plist>
EOF
      else
        cat <<'EOF'
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>images</key>
  <array/>
</dict>
</plist>
EOF
      fi
    fi
    ;;
esac
exit 0
